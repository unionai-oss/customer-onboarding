# Copy to .env and fill in per customer engagement.
# Loaded by workshop_config.py (client-side only — see the warning there).
#
# This is the BASELINE template: every value is deployment-agnostic. Fill it
# in during workshop prep with the customer's endpoints — the per-deployment
# checklist lives in appendix/A-deployment-adaptation.md.

# Union project/domain the workshop runs in
WORKSHOP_PROJECT=onboarding
WORKSHOP_DOMAIN=development

# Container image registry the Image Builder pushes to. Examples:
#   AWS:   <acct>.dkr.ecr.<region>.amazonaws.com/<repo>
#   GCP:   <region>-docker.pkg.dev/<project>/<repo>
#   Azure: <registry>.azurecr.io/<repo>
# Leave empty where the builder/registry is Union-managed.
IMAGE_REGISTRY=

# Object-store URI task pods can read/write, WITH scheme. Examples:
#   s3://my-company-union-workshop
#   gs://my-company-union-workshop
#   abfs://workshop@myaccount.dfs.core.windows.net
OBJECT_STORE_URI=

# Optional: warehouse connector demo in 02-data-flow (BigQuery example ships
# in the notebook; swap for Snowflake/Databricks per customer)
WAREHOUSE_PROJECT=
WAREHOUSE_DATASET=

# Hugging Face model for the optional vLLM add-on (07-serving)
HF_MODEL_ID=Qwen/Qwen2.5-0.5B-Instruct
