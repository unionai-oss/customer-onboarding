# Copy to .env and fill in with values from your platform team.
# Loaded by workshop_config.py (client-side only — see the warning there).

# Union project/domain the workshop runs in
WORKSHOP_PROJECT=onboarding
WORKSHOP_DOMAIN=development

# Artifact Registry Docker repo the Image Builder pushes to, e.g.
# us-central1-docker.pkg.dev/<GCP_PROJECT>/<REPO>
GAR_REGISTRY=

# GCS bucket available to task pods (the `union` KSA must have access), e.g.
# gs://my-company-union-workshop
GCS_BUCKET=

# BigQuery settings for 05-gcp-data-and-integrations (optional)
BQ_PROJECT=
BQ_DATASET=

# Hugging Face model used in 07-apps-and-inference vLLM demo (optional)
HF_MODEL_ID=Qwen/Qwen2.5-0.5B-Instruct
